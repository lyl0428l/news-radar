# ============================================================
# 新闻爬虫 - 环境变量配置模板
# 使用方法：
#   cp .env.example .env
#   然后编辑 .env，填入真实值
#
# 注意：
#   - .env 文件包含密码等敏感信息，绝不能提交到 Git
#   - 服务器上由 deploy.sh 自动生成，或手动创建
# ============================================================

# ============ Web 服务端口 ============
# 宿主机对外暴露的端口，浏览器访问 http://服务器IP:WEB_PORT
WEB_PORT=8888

# ============ 微信推送（PushPlus） ============
# 访问 https://www.pushplus.plus 微信扫码登录后复制 Token
# 留空则关闭微信推送
PUSH_ENABLED=true
PUSH_TOKEN=
PUSH_TOPIC=

# ============ 远程数据同步 ============
# 是否将爬取的新闻同步到远端服务器（如果只有一台服务器，设为 false）
SYNC_ENABLED=false
SYNC_SERVER_URL=
SYNC_USERNAME=
SYNC_PASSWORD=

# ============ Docker 镜像配置（部署脚本使用） ============
DOCKER_IMAGE=news-radar
IMAGE_TAG=latest

# ============ 时区 ============
TZ=Asia/Shanghai
